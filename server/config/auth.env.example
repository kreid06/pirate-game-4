# Copy to auth.env and fill in values. auth.env is gitignored — never commit the real file.
#
#   cp auth.env.example auth.env
#   openssl rand -hex 32 | awk '{print "JWT_SECRET=" $0}' >> auth.env   # or edit JWT_SECRET manually
#   chmod 600 auth.env

AUTH_PORT=3001
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32
CORS_ORIGINS=http://localhost:5173
