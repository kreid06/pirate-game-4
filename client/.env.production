# Production environment variables
# These are baked in at build time (vite build)

# These are overridden by GitHub Actions secrets at build time.
# Set VITE_WS_HOST (and optionally VITE_AUTH_URL) in repo Settings → Secrets.
VITE_WS_PROTOCOL=wss
VITE_WS_HOST=your-server-ip-or-domain
VITE_WS_PORT=8082
VITE_AUTH_URL=https://your-server-ip-or-domain:3001
